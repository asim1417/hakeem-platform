# Supabase PostgreSQL example.
# Replace USER, PASSWORD, HOST, PORT, and DATABASE with values from:
# Supabase Dashboard > Project Settings > Database > Connection string.
DATABASE_URL="postgresql://postgres.USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"

# AUTH_SECRET إلزامي في الإنتاج (يوقّع جلسات المستخدمين). التطبيق يفشل الإقلاع بدونه
# في الإنتاج. وَلِّد قيمة عشوائية طويلة: `openssl rand -base64 32`. لا تشاركها إطلاقًا.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://your-vercel-project.vercel.app"

# Optional initial admin generated by db:seed.
INITIAL_ADMIN_EMAIL="admin@hakeem.local"
INITIAL_ADMIN_PASSWORD=""

# وضع «بدون تسجيل دخول» (تطوير محلّي فقط): يتيح الوصول كزائر بأدنى صلاحية (TRAINEE).
# مغلق افتراضيًا (المصادقة إلزامية). **يُتجاهَل تمامًا في الإنتاج** (NODE_ENV=production)
# فلا يمكن تشغيل الموقع الحيّ بلا تسجيل دخول. للتطوير المحلّي فقط اضبطه true عند الحاجة.
DISABLE_AUTH="false"

# Server-only AI keys. Never expose these as NEXT_PUBLIC_* values.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# يُستخدم أيضاً لخيار «OCR سحابي فائق الدقة» في منصة الوثائق (/documents/tool):
# عند ضبطه يظهر للمستخدم خيار إرسال الصور وPDF إلى Gemini لقراءة أدق (اختياري،
# الافتراضي يبقى OCR المحلي في المتصفح). المصدر: tools/gemini-ocr-service.
GEMINI_API_KEY=""
# مزوّد ذكاء Legal RAG: mock | claude | openai | gemini.
# الافتراضي mock (محاكاة حتمية بلا مفتاح). أي اختيار بلا مفتاح يسقط منظّماً إلى mock.
AI_PROVIDER="mock"
# نموذج موحّد يتقدّم على نماذج المزوّد الفردية أدناه (اتركه فارغاً لاستخدام افتراضي المزوّد).
AI_MODEL=""
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_MODEL="claude-3-5-haiku-latest"
GEMINI_MODEL="gemini-2.5-flash"

# البحث الدلالي (pgvector / embeddings). مُفعَّل افتراضياً متى توفّر EMBEDDING_API_KEY
# (أو OPENAI_API_KEY) + متجهات مملوءة — لا يلزم ضبط هذا العلَم. للتعطيل صراحةً: false.
# املأ المتجهات عبر workflow «Backfill Embeddings» أو: npx tsx scripts/backfill-embeddings.ts
SEMANTIC_SEARCH=""
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMS="1536"
EMBEDDING_BASE_URL="https://api.openai.com/v1"
CUSTOM_AI_BASE_URL=""
CUSTOM_AI_API_KEY=""
CUSTOM_AI_MODEL="gpt-4o-mini"

# Azure Blob Storage for real attachment storage.
# If omitted, uploads remain metadata-only and do not write to Vercel filesystem.
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_CONTAINER="hakeem-attachments"
AZURE_STORAGE_SAS_TOKEN=""

# SharePoint / Microsoft 365 (Microsoft Graph) — تخزين مرفقات بديل.
# يُفعَّل تلقائياً عند ضبط DRIVE_ID + (توكن جاهز أو بيانات اعتماد التطبيق).
SHAREPOINT_DRIVE_ID=""
SHAREPOINT_ACCESS_TOKEN=""
SHAREPOINT_TENANT_ID=""
SHAREPOINT_CLIENT_ID=""
SHAREPOINT_CLIENT_SECRET=""
# ملاحظة: تسجيل الدخول الموحّد (Microsoft 365 SSO عبر Entra ID) تكامل مصادقة منفصل
# يتطلب مستأجراً وتطبيق OAuth، وليس جزءاً من خلفية تخزين المرفقات أعلاه.

# Hybrid Legal Search — OpenSearch/Elasticsearch (مزوّد اختياري قابل للتبديل).
# إن تُرك OPENSEARCH_URL فارغاً يعمل البحث بالـ PostgreSQL و pgvector فقط دون تعطّل.
OPENSEARCH_URL=""
OPENSEARCH_USERNAME=""
OPENSEARCH_PASSWORD=""
OPENSEARCH_INDEX_LEGAL_ARTICLES="legal_articles"
OPENSEARCH_INDEX_JUDICIAL_CASES="judicial_cases"
# وضع البحث: hybrid | postgres | vector | knowledge_graph | opensearch
SEARCH_PROVIDER_MODE="hybrid"

# تكامل مكتبة تراث (turath.io) — بحث حيّ في كتب التراث الفقهية عبر وسيط الخادم.
# يتطلّب إضافة api.turath.io (و app.turath.io) إلى allowlist الخروج (egress) في بيئة التشغيل.
# المسار قابل للضبط لتسهيل التصحيح عند التحقق من واجهة تراث الفعلية.
TURATH_API_BASE="https://api.turath.io"
TURATH_APP_BASE="https://app.turath.io"
TURATH_SEARCH_PATH="/search?q={q}&precision=2"

# ── أداة معالجة الوثائق العربية (tools/arabic-doc-tool) ──
# عنوان خدمة FastAPI المستقلة (رفع/استخراج/تطبيع/فهرسة/بحث). عند ضبطه تُقدَّم
# الأداة على نفس دومين حكيم تحت المسار /doc-tool (بروكسي في next.config.mjs
# — يتطلب إعادة تشغيل/بناء التطبيق). شغّل الخدمة عبر:
#   docker compose up -d doc-tool   (أو)   npm run tool:docs
DOC_TOOL_URL=""
# كلمة مرور الأداة وسر الجلسة — تُمرَّران لخدمة doc-tool في docker-compose.
DOC_TOOL_PASSWORD=""
DOC_TOOL_SESSION_SECRET=""

# ── منصة الوثائق: تكامل Google Drive (اختياري) ──
# لتفعيل زر «استيراد من Drive». أنشئ OAuth Client (نوع: Web) في Google Cloud Console،
# وأضف Authorized redirect URI: https://<domain>/api/doc-platform/drive/callback
# ثم فعّل Google Drive API. المفاتيح خادمية فقط (لا NEXT_PUBLIC).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── تسجيل الدخول عبر Google (OAuth) — اختياري ──
# من Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URI: https://<domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── بوابة الدخول — Microsoft Entra ID (Azure AD SSO) — اختياري ──
# من Microsoft Entra admin center → App registrations → New registration.
# Redirect URI (Web): https://<domain>/api/auth/callback/microsoft
# API permissions: Microsoft Graph → User.Read (+ openid/email/profile عبر OIDC).
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# معرف المستأجر، أو: common | organizations | consumers
AZURE_AD_TENANT_ID="common"

# بُرد تُمنح دور SYSTEM_ADMIN عند الدخول عبر OAuth (Google أو Microsoft) — مفصولة بفواصل.
# مثال المالك: aasemalfarsi@gmail.com
OAUTH_ADMIN_EMAILS="aasemalfarsi@gmail.com"

# تفعيل حساب المالك تلقائيًا عند إقلاع الخادم (ensure-owner). اختياري — الافتراضي Qalam-1703!
OWNER_BOOTSTRAP_PASSWORD="Qalam-1703!"
# اختياري: تجاوز أصل عنوان إعادة التوجيه إن اختلف عن نطاق الطلب.
OAUTH_REDIRECT_BASE=""

# ── ⚠️ فرض المصادقة (الدخول) ──
# الدخول معطّل افتراضيًا: الموقع مفتوح لأي زائر بدور مدير النظام (مناسب للتطوير).
# قبل الإطلاق العلني افرض المصادقة بضبط: REQUIRE_AUTH=true (ثم أعد النشر).
REQUIRE_AUTH=""

# ── Clerk (المصادقة الوحيدة — أُلغي hakeem_session / OAuth اليدوي) ──
# من https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Webhook endpoint: https://<domain>/api/webhooks/clerk  (أحداث user.created/updated/deleted)
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# بعد الدخول دائمًا إلى نقطة التوحيد ثم /dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/auth/continue"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/auth/continue"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/auth/continue"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/auth/continue"
# ⚠️ للإنتاج استخدم مفاتيح pk_live_ / sk_live_ من Instance → Production
# مفاتيح pk_test_ على النطاق الحيّ تسبب سلوكًا غير مستقر (dev-browser-missing).

# ── الحصّة المجانية ──
FREE_QUOTA="20"
WARN_AT="3"

# ── Moyasar (دفع حيّ عند ضبط المفتاح السري) ──
MOYASAR_SECRET_KEY=""
MOYASAR_PUBLISHABLE_KEY=""
MOYASAR_WEBHOOK_SECRET=""

# ── البريد (Resend) — ترحيب عند التسجيل ──
RESEND_API_KEY=""
RESEND_FROM="حكيم <onboarding@hakeem.sa>"

# ── OTP جوال (Twilio) — بلا مفاتيح يُكشف الرمز في التطوير ──
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
# اكشف رمز OTP في الاستجابة عند غياب Twilio (للتطوير)
OTP_DEV_REVEAL=""
