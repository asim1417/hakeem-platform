generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum UserRole {
  SYSTEM_ADMIN
  LAWYER
  TRAINER
  TRAINEE
}

enum AuditSubject {
  AUTH
  LIBRARY
  CASE
  CONSULTATION
  SIMULATION
  TRAINING
  AI_GATEWAY
  ADMIN
}

enum CaseStatus {
  OPEN
  UNDER_REVIEW
  CLOSED
}

enum SimulationStage {
  CLAIM_FILING
  INITIAL_ADMISSIBILITY
  HEARING_RECORD
  PLAINTIFF_STATEMENT
  DEFENDANT_RESPONSE
  PROCEDURAL_DECISION
  PLEADING
  SETTLEMENT
  CLOSE_PLEADING
  TRAINING_JUDGMENT
  OBJECTION
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              UserRole           @default(TRAINEE)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  cases             CaseFile[]
  consultations     Consultation[]
  simulations       Simulation[]
  auditEvents       AuditEvent[]
  training          TrainingProgress[]
  annotations       Annotation[]
  folders           Folder[]
  chatConversations ChatConversation[]
  simulationCases   SimulationCase[]

  @@map("users")
}

model RoleRecord {
  id          String           @id @default(cuid())
  key         UserRole         @unique
  name        String
  permissions RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("roles")
}

model PermissionRecord {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  permissions RolePermission[]
  createdAt   DateTime         @default(now())

  @@map("permissions")
}

model RolePermission {
  id           String           @id @default(cuid())
  roleId       String
  role         RoleRecord       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   PermissionRecord @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model LegalSystem {
  id             String         @id @default(cuid())
  name           String         @unique
  classification String?
  code           String?        @unique // الرمز الفريد من ملف التصنيف (مثل CIV-001)
  domain         String? // المجال المصنّف
  domainTitle    String?        @map("domain_title") // العنوان العربي للمجال
  sortOrder      Int            @default(0) @map("sort_order")
  eliSlug        String?        @unique @map("eli_slug") // slug تشريعي ثابت (يُجمّد عند الإنشاء) — أساس معرّف ELI الدائم
  articleCount   Int            @default(0)
  articles       LegalArticle[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([domain])
  @@index([sortOrder])
  @@map("legal_systems")
}

model LegalArticle {
  id             String                 @id @default(cuid())
  legalSystemId  String?
  legalSystem    LegalSystem?           @relation(fields: [legalSystemId], references: [id])
  lawName        String
  classification String?
  articleNumber  Int
  title          String
  content        String
  chapter        String?
  keywords       String[]               @default([])
  royalDecree    String?
  effectiveFrom  DateTime?
  status         String                 @default("سارية")
  // ── المرحلة ١.ب: تفكيك المعيار (normative tagging) ──
  // الأعمدة الفيزيائية norm_* موجودة عبر الهجرة (20260716120000_add_normative_tagging)،
  // لكنها **مقصودة خارج موديل Prisma**: إبقاؤها هنا يُجبر أي findUnique/findMany بلا select
  // على SELECTها فيكسر على قاعدةٍ لم تُطبَّق عليها الهجرة بعد. القراءة/الكتابة عبر SQL خام
  // فقط (substrate/queries.ts + scripts/tag-normative.ts) — فيبقى آمنًا قبل الهجرة وبعدها.
  // @deprecated (المرحلة ٥): مصدر الـembedding الوحيد هو جدول pgvector «embeddings».
  // لا يُكتب إليه بعد الآن (التوليد يذهب للجدول مباشرة)؛ يبقى أرشيفًا للقراءة الاحتياطية
  // فقط ولا يُحذف. لا تعتمد عليه كمصدر حقيقة.
  embedding      Json?
  caseLinks      LegalArticleCaseLink[]
  amendments     ArticleAmendment[]
  versions       ArticleVersion[]
  graphNodes     LegalGraphNode[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([lawName, articleNumber])
  @@index([lawName])
  @@index([legalSystemId]) // فلتر systemIds (مساواة) — يُنشأ فعليًّا على Neon عبر legal-articles-extra-indexes.sql
  // ملاحظة: فهرس norm_modality/norm_addressee يُنشأ عبر الهجرة (خارج الموديل عمدًا — انظر أعلاه).
  @@map("legal_articles")
}

// ── تتبّع التعديلات والإصدارات التاريخية للمادة (حوكمة قانونية) ──
// كل سجلّ يمثّل واقعة تعديل: المرسوم/الأداة، التاريخ، نوع التغيير، والنصّان.
model ArticleAmendment {
  id            String       @id @default(cuid())
  articleId     String
  article       LegalArticle @relation(fields: [articleId], references: [id])
  // ترتيب الإصدار (1 = الأقدم). يميّز نسخ المادة عبر الزمن.
  version       Int          @default(1)
  changeType    String       @default("amended") // amended | repealed | reinstated | corrected
  decreeRef     String? // مرجع المرسوم/الأمر المُحدِث، مثل: «م/191 وتاريخ ...»
  effectiveFrom DateTime?
  hijriDate     String? // التاريخ الهجري كما ورد
  summary       String? // ملخّص التعديل
  previousText  String? // نصّ المادة قبل التعديل (إن توفّر)
  newText       String? // نصّ المادة بعد التعديل (إن توفّر)
  source        String       @default("manual") // manual | extractor | import
  reviewStatus  String       @default("needs_review")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([articleId, version])
  @@index([articleId])
  @@index([effectiveFrom])
  @@map("article_amendments")
}

// ── النسخ الزمنية للمادة (Akoma Ntoso-style: Work=المادة، Expression=النسخة) ──
// كل سجلّ يمثّل «حالة» نصّ المادة في مدى زمني (من/إلى) — لاسترجاع «النصّ الساري
// بتاريخ X». versionText ثابت بعد الإنشاء (تصحيح = نسخة جديدة، لا تحرير).
// النسخة النافذة حاليًا: effectiveTo = null (واحدة كحدّ أقصى لكل مادة).
model ArticleVersion {
  id             String           @id @default(cuid())
  articleId      String           @map("article_id")
  article        LegalArticle     @relation(fields: [articleId], references: [id])
  versionText    String           @map("version_text") // النصّ الكامل النافذ في هذه النسخة
  effectiveFrom  DateTime?        @map("effective_from")
  effectiveTo    DateTime?        @map("effective_to") // null = النسخة النافذة حاليًا
  royalDecree    String?          @map("royal_decree")
  hijriDate      String?          @map("hijri_date")
  supersededById String?          @map("superseded_by")
  supersededBy   ArticleVersion?  @relation("VersionChain", fields: [supersededById], references: [id])
  supersedes     ArticleVersion[] @relation("VersionChain")
  source         String           @default("derived") // derived | manual | amendment | import
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([articleId, effectiveFrom])
  @@index([effectiveTo])
  @@map("article_versions")
}

model JudicialCase {
  id               String                 @id @default(cuid())
  sourceId         Int?                   @unique
  sourcePageId     Int?
  decisionNo       String?
  caseNo           String?
  courtOfAppeal    String?
  cityOfAppeal     String?
  court            String?
  cityName         String?
  decisionDateText String?
  caseDateText     String?
  decisionDate     DateTime?
  caseDate         DateTime?
  classification   Json?
  judgmentTitle    String?
  judgmentText     String
  appealText       String?
  sourceLink       String?
  source           String                 @default("ahkam_moj")
  reviewStatus     String                 @default("needs_review")
  articleLinks     LegalArticleCaseLink[]
  principles       JudicialPrinciple[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([caseNo])
  @@index([decisionNo])
  @@index([court])
  @@index([cityName])
  @@index([decisionDate])
  @@map("judicial_cases")
}

model LegalArticleCaseLink {
  id           String       @id @default(cuid())
  articleId    String
  article      LegalArticle @relation(fields: [articleId], references: [id])
  caseId       String
  judicialCase JudicialCase @relation(fields: [caseId], references: [id])
  relationType String
  citedText    String?
  excerpt      String?
  explanation  String?
  confidence   Float?
  reviewStatus String       @default("needs_review")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([articleId, caseId, citedText])
  @@index([articleId])
  @@index([caseId])
  @@index([relationType])
  @@map("legal_article_case_links")
}

model JudicialPrinciple {
  id            String       @id @default(cuid())
  title         String
  principleText String
  sourceCaseId  String
  sourceCase    JudicialCase @relation(fields: [sourceCaseId], references: [id])
  court         String?
  topic         String?
  confidence    Float?
  reviewStatus  String       @default("needs_review")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([sourceCaseId])
  @@map("judicial_principles")
}

model GlossaryTerm {
  id        String   @id @default(cuid())
  term      String   @unique
  meaning   String
  createdAt DateTime @default(now())

  @@map("glossary_terms")
}

model CaseFile {
  id          String       @id @default(cuid())
  title       String
  summary     String?
  status      CaseStatus   @default(OPEN)
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])
  attachments Attachment[]
  annotations Annotation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("cases")
}

model Attachment {
  id            String    @id @default(cuid())
  caseId        String?
  caseFile      CaseFile? @relation(fields: [caseId], references: [id])
  fileName      String
  mimeType      String
  storageKey    String
  extractedText String?
  createdAt     DateTime  @default(now())

  @@map("attachments")
}

model Consultation {
  id            String                 @id @default(cuid())
  userId        String
  user          User                   @relation(fields: [userId], references: [id])
  caseId        String?
  facts         String
  status        String                 @default("DRAFT")
  output        String?
  qualityReport Json?
  citations     ConsultationCitation[]
  messages      Message[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@map("consultations")
}

model ConsultationCitation {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  articleId      String
  lawName        String
  articleNumber  Int
  quote          String
  createdAt      DateTime     @default(now())

  @@map("consultation_citations")
}

model Message {
  id             String        @id @default(cuid())
  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id])
  role           String
  content        String
  createdAt      DateTime      @default(now())

  @@map("messages")
}

model Simulation {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  title     String
  stage     SimulationStage      @default(CLAIM_FILING)
  messages  SimulationMessage[]
  decisions SimulationDecision[]
  judgments SimulationJudgment[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@map("simulation_sessions")
}

model SimulationMessage {
  id           String          @id @default(cuid())
  simulationId String
  simulation   Simulation      @relation(fields: [simulationId], references: [id])
  role         String
  stage        SimulationStage
  content      String
  createdAt    DateTime        @default(now())

  @@map("simulation_messages")
}

model SimulationDecision {
  id            String          @id @default(cuid())
  simulationId  String
  simulation    Simulation      @relation(fields: [simulationId], references: [id])
  stage         SimulationStage
  decisionType  String
  content       String
  exportPdfKey  String?
  exportDocxKey String?
  createdAt     DateTime        @default(now())

  @@map("simulation_decisions")
}

model SimulationJudgment {
  id           String          @id @default(cuid())
  simulationId String
  simulation   Simulation      @relation(fields: [simulationId], references: [id])
  stage        SimulationStage @default(TRAINING_JUDGMENT)
  content      String
  disclaimer   String          @default("هذا حكم تدريبي غير ملزم ولا يعد حكمًا فعليًا.")
  createdAt    DateTime        @default(now())

  @@map("simulation_judgments")
}

model Exercise {
  id          String   @id @default(cuid())
  title       String
  description String
  content     Json
  createdAt   DateTime @default(now())

  @@map("exercises")
}

model TrainingProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  badges    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("training_progress")
}

model FeatureToggle {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("feature_toggles")
}

model GuardrailDecision {
  id        String       @id @default(cuid())
  subject   AuditSubject
  requestId String
  guardName String
  result    String
  details   Json?
  createdAt DateTime     @default(now())

  @@map("guardrail_decisions")
}

model AuditEvent {
  id        String       @id @default(cuid())
  actorId   String?
  actor     User?        @relation(fields: [actorId], references: [id])
  subject   AuditSubject
  action    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime     @default(now())

  @@index([subject, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// إعدادات عامة للتطبيق (مفتاح/قيمة) — تُستخدم لإعداد الذكاء الاصطناعي مركزياً.
// قراءتها مغلّفة بـ try/catch في الكود، فإن لم يُنشأ الجدول بعد يعود التطبيق
// لمتغيرات البيئة دون تعطّل. التفعيل: prisma db push.
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt

  @@map("app_settings")
}

// بلاغات المشكلات من القاضي التفاعلي (الواجهة الأصلية hakim1111.html).
// تُكتب عبر POST /api/original-hakeem/bug-report وتُقرأ للمالك عبر GET (ADMIN_REPORTS_VIEW).
// القراءة/الكتابة مغلّفة بـ try/catch في الكود، فإن لم يُنشأ الجدول بعد لا يتعطّل
// التطبيق ويعود العميل للحفظ المحلي. التفعيل: prisma db push.
model BugReport {
  id           String   @id @default(cuid())
  type         String
  description  String
  suggestedFix String?
  caseId       String?
  subject      String?
  stage        String?
  context      Json?
  actorId      String?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("bug_reports")
}

// ══════════════════════════════════════════════════════════
// توسعة المرحلة الأولى (CLAUDE.md): Knowledge Graph + pgvector
// إضافية بالكامل — لا تمسّ النماذج القائمة ولا تكسر التطبيق.
// التفعيل على القاعدة لاحقاً عبر migration المرافق (لا يُشغَّل على الإنتاج هنا).
// ══════════════════════════════════════════════════════════

// نوع العلاقة في الرسم المعرفي القانوني (Knowledge Graph)
enum RelationType {
  SUPPORTS
  CONTRADICTS
  INTERPRETS
  IMPLEMENTS
  SUPERSEDES
  RELATED_TO
}

// ── Knowledge Graph: علاقات قانونية متعدّدة الأشكال (polymorphic) ──
// تربط (مادة/حكم/مبدأ/نظام) بأخرى عبر النوع+المعرّف، دون مفاتيح أجنبية
// صارمة لمرونة الربط بين الجداول المختلفة. تُستخدم النماذج القائمة كمصدر
// للمعرّفات: LegalArticle, JudicialCase, JudicialPrinciple, LegalSystem.
model LegalRelation {
  id          String       @id @default(cuid())
  sourceType  String       @map("source_type") // article | ruling | principle | system
  sourceId    String       @map("source_id")
  targetType  String       @map("target_type")
  targetId    String       @map("target_id")
  relation    RelationType
  strength    Float        @default(1.0)
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([relation])
  @@map("legal_relations")
}

// ── متجهات الدلالة (pgvector) ──
// جدول مستقل لتفادي المساس بأعمدة النماذج القائمة. عمود vector يُدار عبر
// استعلامات SQL خام (Unsupported لا يُقرأ/يُكتب عبر عميل Prisma مباشرةً).
model Embedding {
  id        String                       @id @default(cuid())
  ownerType String                       @map("owner_type") // article | ruling | principle
  ownerId     String                       @map("owner_id")
  embedding   Unsupported("vector(1536)")?
  model       String                       @default("text-embedding-3-small")
  contentHash String?                      @map("content_hash") // sha256 لنصّ المصدر — لكشف التقادم وإعادة التضمين التزايُدية
  createdAt   DateTime                     @default(now()) @map("created_at")

  @@unique([ownerType, ownerId])
  @@index([ownerType, ownerId])
  @@map("embeddings")
}

// ── التظليلات والملاحظات ──
model Annotation {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  caseId          String?  @map("case_id")
  documentType    String   @map("document_type") // article | ruling | principle
  documentId      String   @map("document_id")
  highlightedText String?  @map("highlighted_text")
  note            String?
  color           String   @default("#FEF08A")
  createdAt       DateTime @default(now()) @map("created_at")

  user User      @relation(fields: [userId], references: [id])
  case CaseFile? @relation(fields: [caseId], references: [id])

  @@index([userId])
  @@index([documentType, documentId])
  @@map("annotations")
}

// ── المجلدات ──
model Folder {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children Folder[] @relation("FolderHierarchy")

  @@index([userId])
  @@map("folders")
}

// ── المسائل الفقهية (الموسوعة الفقهية ↔ الأنظمة) ──
// جداول مستقلّة، بلا مساس بالجداول الأصلية. الربط بالمواد منطقيّ عبر (law_name, article_number).
model FiqhIssue {
  id               String   @id // = issueId الثابت (fiqh-<sha1>)
  title            String
  path             String
  section          String
  book             String?
  chapter          String?
  nodeType         String   @map("node_type")
  suggestedNizam   String   @map("suggested_nizam")
  linkStatus       String   @map("link_status")
  nizamRatio       Float    @map("nizam_ratio")
  status           String   @default("candidate")
  needsHumanReview Boolean  @default(true) @map("needs_human_review")
  createdAt        DateTime @default(now()) @map("created_at")

  links FiqhIssueLink[]

  @@index([linkStatus])
  @@index([suggestedNizam])
  @@map("fiqh_issues")
}

model FiqhIssueLink {
  id            String   @id @default(cuid())
  issueId       String   @map("issue_id")
  articleId     String?  @map("article_id") // مُحلّ من legal_articles عند البذر (مرجع منطقي)
  lawName       String   @map("law_name")
  articleNumber Int      @map("article_number")
  citation      String
  score         Float
  rank          Int
  createdAt     DateTime @default(now()) @map("created_at")

  issue FiqhIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, lawName, articleNumber])
  @@index([lawName, articleNumber])
  @@index([articleId])
  @@map("fiqh_issue_links")
}

// ── التصنيفات الموضوعية (شجرة) ──
// تصنيف هرمي للموضوعات القانونية (مثال: التزامات ← مسؤولية عقدية ← فسخ).
// مرجعية للفلترة والتنظيم؛ الربط بالمواد/الأحكام منطقيّ عبر الاسم/المعرّف.
model LegalTopic {
  id        String   @id @default(cuid())
  name      String   @unique
  parentId  String?  @map("parent_id")
  path      String   @default("") // مسار هرمي مثل: التزامات/مسؤولية عقدية
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  parent   LegalTopic?  @relation("TopicHierarchy", fields: [parentId], references: [id])
  children LegalTopic[] @relation("TopicHierarchy")

  @@index([parentId])
  @@index([path])
  @@map("legal_topics")
}

// ── سجل البحث (قياس الاستخدام وتحسين الصلة) ──
// userId مرجع منطقيّ اختياري (بلا FK صارمة) كي لا يعتمد التسجيل على وجود مستخدم.
model SearchLog {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  query        String
  filters      Json?
  resultsCount Int      @default(0) @map("results_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([userId])
  @@map("search_logs")
}

// ── الطبقة الفقهية المنضبطة (مساندة غير ملزمة، منفصلة تمامًا عن النظام) ──
// لا تُنشر مواءمة على الواجهة إلا بعد مراجعة بشرية أو موسومة «آلية غير معتمدة».

model FiqhSource {
  id                 String   @id @default(cuid())
  sourceTitle        String   @map("source_title")
  author             String?
  school             String? // المذهب
  era                String?
  sourceType         String   @default("book") @map("source_type")
  edition            String?
  publisher          String?
  verificationStatus String   @default("unverified") @map("verification_status")
  externalId         String?  @unique @map("external_id") // معرّف المصدر الخارجي (مثل تراث)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  texts FiqhText[]

  @@index([author])
  @@map("fiqh_sources")
}

model FiqhText {
  id             String     @id @default(cuid())
  sourceId       String     @map("source_id")
  source         FiqhSource @relation(fields: [sourceId], references: [id])
  book           String?
  chapter        String?
  section        String?
  textOriginal   String     @map("text_original")
  textNormalized String?    @map("text_normalized")
  topic          String?
  legalConceptId String?    @map("legal_concept_id")
  pageReference  String?    @map("page_reference")
  citation       String?
  externalRef    String?    @map("external_ref") // مرجع الصفحة في المصدر الخارجي
  deletedAt      DateTime?  @map("deleted_at") // حذف ناعم
  createdAt      DateTime   @default(now()) @map("created_at")

  alignments FiqhArticleAlignment[]

  @@index([sourceId])
  @@index([topic])
  @@map("fiqh_texts")
}

model FiqhArticleAlignment {
  id              String    @id @default(cuid())
  articleId       String    @map("article_id")
  fiqhTextId      String    @map("fiqh_text_id")
  fiqhText        FiqhText  @relation(fields: [fiqhTextId], references: [id])
  alignmentType   String    @default("topical") @map("alignment_type") // اصل|قاعدة|نظير|خلاف|تأصيل|غير_مناسب
  alignmentReason String?   @map("alignment_reason") // وجه الصلة
  confidenceScore Float?    @map("confidence_score")
  reviewStatus    String    @default("needs_review") @map("review_status")
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([articleId, fiqhTextId])
  @@index([articleId])
  @@index([reviewStatus])
  @@map("fiqh_article_alignments")
}

// ─────────────────────────────────────────────────────────────────────────────
// منصة العمل القضائية الذكية (Legal AI Workspace) — الشات القضائي + المحاكاة
// المرحلة التاسعة: الحفظ. ملاحظة حوكمة: لا تُطبَّق هذه الجداول على قاعدة الإنتاج
// إلا عبر migration وبإذن صريح. كود الحفظ في التطبيق best-effort (try/catch)
// بحيث تعمل الواجهة حتى قبل تفعيل الجداول.
// ─────────────────────────────────────────────────────────────────────────────

model ChatConversation {
  id        String          @id @default(cuid())
  title     String
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id])
  caseId    String?         @map("case_id")
  case      SimulationCase? @relation(fields: [caseId], references: [id])
  mode      String          @default("RESEARCHER")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id              String           @id @default(cuid())
  conversationId  String           @map("conversation_id")
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String // user | assistant | system
  content         String
  attachments     Json?
  extractedIntent Json?            @map("extracted_intent")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("chat_messages")
}

model SimulationCase {
  id                   String   @id @default(cuid())
  title                String
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id])
  userRole             String?  @map("user_role")
  disputeType          String?  @map("dispute_type")
  trackType            String?  @map("track_type")
  proceduralStage      String?  @map("procedural_stage")
  status               String   @default("DRAFT")
  summary              String?
  claimValue           String?  @map("claim_value")
  hasArbitrationClause Boolean? @map("has_arbitration_clause")
  facts                Json?
  parties              Json?
  evidence             Json?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  conversations ChatConversation[]
  runs          SimulationRun[]

  @@index([userId])
  @@map("simulation_cases")
}

model SimulationRun {
  id                 String          @id @default(cuid())
  caseId             String?         @map("case_id")
  case               SimulationCase? @relation(fields: [caseId], references: [id])
  userId             String?         @map("user_id")
  mode               String
  outputType         String?         @map("output_type")
  inputSnapshot      Json?           @map("input_snapshot")
  understoodRequest  Json?           @map("understood_request")
  userApprovalStatus String          @default("PENDING") @map("user_approval_status")
  retrievedArticles  Json?           @map("retrieved_articles")
  output             String?
  warnings           Json?
  confidence         Float?
  createdAt          DateTime        @default(now()) @map("created_at")

  @@index([caseId])
  @@map("simulation_runs")
}

// ============================================================================
//  الرسم القانوني رباعي الطبقات — نظام / لائحة / ضابط / دليل إجرائي
//  (حزمة hakeem-bylaw-linking) — يُعمّم الربط الثنائي إلى property graph في SQL.
//  المصدر الأوّلي: بيانات بوابة العدل المُدرَجة؛ قابل لدمج nezams لاحقًا (upsert idempotent).
// ============================================================================

enum LegalNodeType {
  SYSTEM_ARTICLE // مادة نظام
  BYLAW_ARTICLE // مادة لائحة تنفيذية
  CONTROL // ضابط
  PROCEDURE // دليل / إجراء إجرائي
}

enum LegalRelationType {
  IMPLEMENTS // لائحة تُنفّذ/تُفصّل مادة نظام
  GOVERNED_BY // بند يخضع لضابط
  PROCEDURE_FOR // إجراء لتنفيذ بند
  REFERS // إحالة مجرّدة
  DETAILS // تفصيل
  AMENDS // تعديل
}

enum RelationSource {
  STRUCTURAL // محاذاة بنيوية من ترتيب الصفحة/النظام الأمّ
  EXPLICIT // إشارة نصية صريحة «المادة (كذا) من النظام»
  MANUAL // إدخال/إقرار بشري
}

model LegalGraphNode {
  id        String        @id // معرّف المُستخرِج (SYS::law::n) أو cuid
  type      LegalNodeType
  law       String // اسم/معرّف النظام
  number    Int?
  seq       Int?
  body      String?       @db.Text
  sourceUrl String?
  articleId String? // ربط اختياري بمادة قائمة في legal_articles
  article   LegalArticle? @relation(fields: [articleId], references: [id])

  outgoing LegalGraphEdge[] @relation("RelSource")
  incoming LegalGraphEdge[] @relation("RelTarget")

  @@index([type])
  @@index([law, number])
  @@index([articleId])
  @@map("legal_graph_nodes")
}

model LegalGraphEdge {
  id         String            @id @default(cuid())
  sourceId   String
  targetId   String
  type       LegalRelationType @default(IMPLEMENTS)
  evidence   String?           @db.Text
  confidence Float             @default(0.9)
  source     RelationSource    @default(STRUCTURAL)
  verifiedBy String?
  createdAt  DateTime          @default(now())

  sourceNode LegalGraphNode @relation("RelSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetNode LegalGraphNode @relation("RelTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type]) // idempotent → upsert آمن، والأعلى ثقة يرجّح
  @@index([targetId])
  @@index([sourceId])
  @@map("legal_graph_edges")
}

// ═══ منصة الوثائق (منتج مستقل — يستخدم البنية للنشر فقط) ═══

// مساحة عمل مربوطة بكوكي متصفح (بلا حساب) — تنتقل لاحقاً لحساب مستخدم عند تفعيل المصادقة
model DocWorkspace {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String    @unique // قيمة الكوكي (عشوائية 128-bit)
  prefs     Json? // تفضيلات القراءة (سمة/خط/أسطر…)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  cases     DocCase[]

  @@map("doc_workspaces")
}

// «قضية» محفوظة: مجموعة وثائق + ملاحظاتها وأعلامها ومقتطفاتها
model DocCase {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String       @map("workspace_id") @db.Uuid
  title       String
  docs        Json // [{title, rawText}]
  annotations Json? // {notes:{}, flags:{}, quotes:[]}
  docCount    Int          @default(0) @map("doc_count")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  workspace   DocWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("doc_cases")
}

// ── بوابة API الخارجية: مفاتيح الأطراف الثالثة (توكن مُخزَّن مُجزَّأ لا خام) ──
// keyHash = SHA-256 للمفتاح الكامل (لا يُخزَّن الخام أبدًا)؛ keyPrefix للعرض/الإدارة.
model ApiKey {
  id          String    @id @default(cuid())
  name        String // وصف بشري للمفتاح (لمن/لماذا)
  keyPrefix   String    @unique @map("key_prefix") // بادئة ظاهرة مثل hk_live_ab12cd34
  keyHash     String    @unique @map("key_hash") // SHA-256 للمفتاح الكامل
  scopes      String[]  @default([]) // نطاقات الوصول، مثل ["legal:read"]
  rateLimit   Int       @default(60) @map("rate_limit") // طلبات لكل نافذة دقيقة
  active      Boolean   @default(true)
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  windows ApiRequestWindow[]

  @@index([keyPrefix])
  @@map("api_keys")
}

// نافذة حدّ المعدّل (fixed window لكل دقيقة) — عدّاد ذرّي عبر UPSERT، يصمد عبر النسخ الخادمية.
model ApiRequestWindow {
  id          String   @id @default(cuid())
  apiKeyId    String   @map("api_key_id")
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  windowStart Int      @map("window_start") // رقم الدقيقة (epoch/60000)
  count       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([apiKeyId, windowStart])
  @@index([windowStart])
  @@map("api_request_windows")
}

// ═══════════════════════════════════════════════════════════════════════════
// طبقة استخراج بطاقات الأحكام (داخلية — لا تظهر في الواجهات حتى اعتماد المراجعة)
// جداول مخرجات فقط: تُشير إلى judicial_cases عبر FK على مستوى القاعدة (بلا علاقات
// Prisma عكسية كي لا تُمَسّ جداول المصدر). الجدول المعتمد للحكم = judicial_cases.
// ═══════════════════════════════════════════════════════════════════════════

// بطاقة حكم مهيكلة مستخرَجة (مرآة الحكم لا توليد). review_status: auto|needs_review|approved|rejected
model JudgmentCard {
  id               String   @id @default(cuid())
  judgmentId       String   @unique @map("judgment_id") // FK → judicial_cases.id (قاعدةً)
  card             Json // مخطّط البطاقة الثابت (disputeType, claims, defenses, appliedArticles, result…)
  confidence       Float    @default(0)
  extractorVersion String   @map("extractor_version")
  verifierAgreed   Boolean? @map("verifier_agreed") // نتيجة التدقيق المستقل (null = لم يُدقَّق)
  reviewStatus     String   @default("auto") @map("review_status") // auto | needs_review | approved | rejected
  calibration      Boolean  @default(false) // ضمن عيّنة المعايرة المحجوزة (100)
  runId            String?  @map("run_id") // FK → extraction_runs.id (قاعدةً)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([reviewStatus])
  @@index([calibration])
  @@index([runId])
  @@map("judgment_cards")
}

// رابط مادة←حكم بحبيبة الاستخراج الخام (رقم المادة نصًّا كما ورد + السياق). الوقود الأولي للفهرس العكسي.
model JudgmentArticleLink {
  id            String   @id @default(cuid())
  judgmentId    String   @map("judgment_id") // FK → judicial_cases.id (قاعدةً)
  legalSystemId String?  @map("legal_system_id") // FK → legal_systems.id بعد التطبيع (قد لا يُطابَق)
  articleNumber String   @map("article_number") // كما ورد حرفيًّا في الحكم (نصّ)
  articleId     String?  @map("article_id") // FK → legal_articles.id إن أمكن الربط الدقيق
  context       String   @db.Text // الجملة الحاملة للذكر في نصّ الحكم
  verified      Boolean  @default(false) // المادة موجودة نصًّا في الحكم (فحص اتساق)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([judgmentId])
  @@index([legalSystemId, articleNumber])
  @@index([articleId])
  @@map("judgment_article_links")
}

// سجلّ تشغيلة استخراج (نقاط استئناف + إحصاء) — أداة التشغيل الليلي والتقرير.
model ExtractionRun {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  processed     Int       @default(0)
  failed        Int       @default(0)
  avgConfidence Float?    @map("avg_confidence")
  notes         String?   @db.Text

  @@map("extraction_runs")
}
